{
  "name": "measurements-frontend",
  "version": "1.0.8",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "install-deps": "npm install",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "format": "prettier --write --experimental-cli --cache-location node_modules/.cache/prettier vite.config.ts eslint.config.js src/ tests/",
    "format-check": "prettier --check --experimental-cli --cache-location node_modules/.cache/prettier vite.config.ts eslint.config.js src/ tests/",
    "lint": "eslint .",
    "outdated": "npm outdated",
    "update": "npx npm-check-updates -u",
    "version-patch": "npm version patch",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui"
  },
  "dependencies": {
    "beercss": "^4.0.21",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.4.0",
    "fp-ts": "^2.16.11",
    "io-ts": "^2.2.22",
    "io-ts-types": "^0.5.19",
    "vue": "^3.5.38",
    "vue-chartjs": "^5.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "3.8.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vue-tsc": "^3.3.5"
  }
}
